OPENROUTER_API_KEY=
OPENROUTER_MODEL=tencent/hy3-preview:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_NAME=Portexa AI# App
APP_NAME=Portexa API
ENV=development

# Security
JWT_SECRET_KEY=change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/portexa

# CORS
CORS_ORIGINS=http://localhost:5173

# Login lockout
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_MINUTES=30
